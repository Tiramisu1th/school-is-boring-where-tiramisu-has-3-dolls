<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Serve existing files/directories (file exists or directory exists)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Redirect explicit index pages to root (keep canonical URL)
  RewriteRule ^index(?:\.html)?$ / [R=301,L]

  # If request has no extension and a corresponding .html file exists, internally serve it
  # (e.g. /avalon -> /avalon.html)
  RewriteCond %{REQUEST_URI} !\.[^/]+$
  RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}.html -f
  RewriteRule ^ %{REQUEST_URI}.html [L]

  # Avoid redirect loop when serving the 404 page itself
  RewriteCond %{REQUEST_URI} !^/404\.html$
  # No matching file: return the static 404 page with HTTP 404
  RewriteRule ^ /404.html [L,R=404]
</IfModule>

Options -Indexes
