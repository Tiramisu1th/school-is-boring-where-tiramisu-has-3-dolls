{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "noEmit": false,
        "outDir": "out",
        "rootDir": ".",
        "module": "commonjs",
        "target": "ES2019",
        "emitDeclarationOnly": false,
        "types": [
            "node"
        ]
    },
    "include": [
        "src/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "out"
    ]
}