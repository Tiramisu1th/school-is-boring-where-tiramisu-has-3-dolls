{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "rootDir": "src",
        "outDir": "out/src",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": false,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "allowSyntheticDefaultImports": true,
        "noEmitOnError": false,
        "types": ["node"]
    },
    "include": [
        "src/api/**/*",
        "src/utils/**/*"
    ],
    "exclude": [
        "node_modules"
    ]
}